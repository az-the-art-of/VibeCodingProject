<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>

<main class="container section">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Admin</p>
      <h1>Club management dashboard</h1>
    </div>
    <a class="button" href="/admin/clubs/new">Create new club</a>
  </div>

  <section class="panel">
    <h2>Club listings</h2>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Location</th>
            <th>Category</th>
            <th>Saved</th>
            <th>Reviews</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% clubs.forEach((club) => { %>
            <tr>
              <td><a href="/clubs/<%= club.id %>"><%= club.name %></a></td>
              <td><%= club.location %></td>
              <td><%= club.category %></td>
              <td><%= club.favourite_count %></td>
              <td><%= club.review_count %></td>
              <td>
                <div class="table-actions">
                  <a class="button button-secondary button-small" href="/admin/clubs/<%= club.id %>/edit">Edit</a>
                  <form action="/admin/clubs/<%= club.id %>/delete" class="inline-form" method="post">
                    <input name="_csrf" type="hidden" value="<%= csrfToken %>" />
                    <button class="button button-danger button-small" type="submit">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <h2>Contact submissions</h2>
    <% if (contactRequests.length === 0) { %>
      <p class="muted">No contact submissions yet.</p>
    <% } %>
    <div class="stack-list">
      <% contactRequests.forEach((request) => { %>
        <article class="compact-entry">
          <h3><a href="/clubs/<%= request.club_id %>"><%= request.club_name %></a></h3>
          <p><strong><%= request.display_name %></strong> (<%= request.email %>)</p>
          <p><%= request.message %></p>
          <p class="muted"><%= formatDate(request.created_at) %></p>
        </article>
      <% }) %>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
