<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>

<main class="container section">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Search results</p>
      <h1>Browse local clubs</h1>
    </div>
    <p class="muted"><%= resultCount %> club<%= resultCount === 1 ? "" : "s" %> found</p>
  </div>

  <% if (errorMessage) { %>
    <div class="flash flash-error"><%= errorMessage %></div>
  <% } %>

  <%- include("../partials/search-form", { search }) %>

  <section class="results-grid">
    <% if (clubs.length === 0) { %>
      <div class="empty-state">
        <h2>No clubs matched those filters</h2>
        <p>Try broadening your search or removing a filter.</p>
      </div>
    <% } %>

    <% clubs.forEach((club) => { %>
      <article class="card card-horizontal">
        <img alt="" class="card-image" src="<%= club.image_url %>" />
        <div class="card-body">
          <div class="card-meta">
            <span><%= club.category %></span>
            <span><%= club.activity_type %></span>
            <span><%= club.location %></span>
          </div>
          <h2><a href="/clubs/<%= club.id %>"><%= club.name %></a></h2>
          <p><%= club.description %></p>
          <div class="card-meta">
            <span><%= club.meeting_frequency %></span>
            <span><%= club.meeting_time %></span>
            <span><%= club.average_rating > 0 ? `${club.average_rating}/5` : "No ratings yet" %></span>
          </div>
          <div class="card-meta">
            <span><%= club.price_type %></span>
            <span><%= club.venue_type %></span>
            <% if (club.is_favourite) { %>
              <span>Saved</span>
            <% } %>
          </div>
        </div>
      </article>
    <% }) %>
  </section>
</main>

<%- include("../partials/footer") %>
